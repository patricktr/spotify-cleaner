# Spotify OAuth — create app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/spotify/callback

# Neon Postgres — auto-populated by `vercel env pull` after Marketplace integration
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# App-side AES-GCM key for encrypting stored Spotify refresh tokens
# Generate: node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
TOKEN_ENCRYPTION_KEY=

# Anthropic API key for the LLM classifier (OPTIONAL).
# Without it, the heuristics still run; any track the heuristics can't resolve
# gets a synthetic `borderline` verdict (confidence 0.5) and lands in the review
# queue instead of being auto-actioned.
ANTHROPIC_API_KEY=

# Optional override to disable the LLM classifier even when ANTHROPIC_API_KEY is
# set (useful for cost-control testing). Set to `false` to force heuristics-only
# mode; any other value (or unset) leaves the LLM enabled when the key exists.
LLM_CLASSIFIER_ENABLED=

# Cron auth — Vercel injects this when you configure crons in vercel.json
CRON_SECRET=
