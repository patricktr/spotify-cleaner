# Spotify OAuth — create app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/spotify/callback

# Neon Postgres — auto-populated by `vercel env pull` after Marketplace integration
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# App-side AES-GCM key for encrypting stored Spotify refresh tokens
# Generate: node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
TOKEN_ENCRYPTION_KEY=

# Anthropic API key for the LLM classifier
ANTHROPIC_API_KEY=

# Cron auth — Vercel injects this when you configure crons in vercel.json
CRON_SECRET=
